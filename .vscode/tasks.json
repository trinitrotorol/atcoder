{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AtCoder: setup WSL env",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\setup-wsl.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "AtCoder: build",
      "type": "shell",
      "command": "wsl",
      "args": [
        "-d",
        "Ubuntu",
        "--",
        "bash",
        "-lc",
        "cd \"$(wslpath -a '${workspaceFolder}')\" && ./scripts/compile.sh"
      ],
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "AtCoder: run",
      "type": "shell",
      "command": "wsl",
      "args": [
        "-d",
        "Ubuntu",
        "--",
        "bash",
        "-lc",
        "cd \"$(wslpath -a '${workspaceFolder}')\" && ./scripts/run.sh"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    }
  ]
}

